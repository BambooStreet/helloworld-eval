# MongoDB Atlas URI - RAG 시스템 근거 문서 데이터베이스
RAG_DATA_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ragdb?retryWrites=true&w=majority

# MongoDB Atlas URI - 채팅 로그 데이터베이스
LOG_DATA_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatdb?retryWrites=true&w=majority

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Secret Key (인증용)
JWT_SECRET_KEY=your-jwt-secret-key-here
